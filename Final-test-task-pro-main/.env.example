# This file lists every environment variable required by the project.
# Setup:
# 1) Copy this file to .env (do not commit .env)
# 2) Fill in values from your providers
#
# Supabase credentials: Supabase Project Settings -> API
# OneSignal App ID: OneSignal Dashboard -> Settings -> Keys & IDs
# .env should NEVER be committed to git.
#
# Troubleshooting:
# - "Missing required environment variable" means your .env is missing a key.
# - "Supabase mock client is disabled in production builds." means you are using demo values in production.
# - If OneSignal push is not working, verify your App ID matches the correct OneSignal app.

# ------------------------------------------------------------
# Frontend (Web) - Vite
# ------------------------------------------------------------
# Supabase project URL or proxy URL used by the web app
VITE_SUPABASE_URL=https://your-project.supabase.co
# Supabase anon/public key (safe for client use)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# OneSignal Web App ID for push notifications
VITE_ONESIGNAL_APP_ID=your-onesignal-app-id

# Sentry DSN (optional error tracking)
VITE_SENTRY_DSN=

# Firebase API key (if Firebase is enabled)
VITE_FIREBASE_API_KEY=your-firebase-api-key
# Firebase auth domain
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# Firebase project id
VITE_FIREBASE_PROJECT_ID=your-project-id
# Firebase storage bucket
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# Firebase messaging sender id
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
# Firebase app id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# ------------------------------------------------------------
# Backend (Python)
# ------------------------------------------------------------
# MongoDB connection string
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/dbname

# MongoDB database name
DB_NAME=your-database-name

# CORS Security: Comma-separated list of allowed origins
# Example: http://localhost:5173,http://localhost:3000,https://your-production-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-production-domain.com

# Gemini / AI services API key (if enabled)
API_KEY=your-gemini-api-key

# ------------------------------------------------------------
# Mobile (Expo)
# ------------------------------------------------------------
# Supabase URL for mobile app
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Supabase anon key for mobile app
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# OneSignal App ID for mobile push
EXPO_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# ------------------------------------------------------------
# Supabase Edge Functions (Secrets)
# ------------------------------------------------------------
# Supabase URL for edge functions
SUPABASE_URL=https://your-project.supabase.co
# Supabase service role key (server-only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OneSignal App ID for server-side notifications
ONESIGNAL_APP_ID=your-onesignal-app-id
# OneSignal REST API key
ONESIGNAL_API_KEY=your-onesignal-rest-api-key

# Twilio Account SID
TWILIO_ACCOUNT_SID=your-twilio-account-sid
# Twilio Auth Token
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Twilio WhatsApp sender number
TWILIO_PHONE_NUMBER=whatsapp:+14155552671

# Optional: Protect recurring reminder endpoint
RECURRING_CRON_SECRET=your-recurring-cron-secret
