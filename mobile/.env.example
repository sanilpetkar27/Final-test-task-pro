# Mobile (Expo) environment variables
# Copy to .env and fill in your values.

# Supabase URL for the mobile client
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Supabase anon key for the mobile client
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# OneSignal App ID for mobile push notifications
EXPO_PUBLIC_ONESIGNAL_APP_ID=YOUR_ONESIGNAL_APP_ID
