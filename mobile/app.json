{
  "expo": {
    "name": "OpenTask",
    "slug": "opentask-mobile",
    "scheme": "opentask",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.opentask.mobile"
    },
    "android": {
      "package": "com.opentask.mobile"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ]
    ]
  }
}
